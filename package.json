{
    "name": "faqs",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.30.3",
    "scripts": {
        "deps:check": "npx npm-check-updates@latest --configFileName ncurc.yml --workspaces --root --mergeConfig",
        "deps:update": "npx npm-check-updates@latest --configFileName ncurc.yml -u --workspaces --root --mergeConfig",
        "g:lint": "TIMING=1 turbo run lint --cache-dir=.cache/turbo --color",
        "g:lint-staged-files": "lint-staged --allow-empty",
        "build-faqs-web": "turbo run build-faqs-web",
        "start-faqs-web": "turbo run start --filter=faqs-web",
        "prepare": "husky"
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.5.0",
        "@changesets/cli": "2.27.1",
        "@commitlint/cli": "19.2.1",
        "@commitlint/config-conventional": "19.1.0",
        "@eslint/compat": "^2.0.2",
        "@types/node": "20.11.30",
        "@types/shell-quote": "1.7.5",
        "cross-env": "7.0.3",
        "eslint": "10.0.1",
        "husky": "9.1.7",
        "lint-staged": "16.2.7",
        "npm-run-all2": "6.1.2",
        "prettier": "3.8.1",
        "rimraf": "5.0.5",
        "shell-quote": "1.8.1",
        "syncpack": "12.3.0",
        "turbo": "2.8.11",
        "typescript": "5.8.2",
        "typescript-eslint": "8.56.1"
    },
    "engines": {
        "node": ">=20.19.0",
        "npm": "please-use-pnpm"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "pnpm": {
        "onlyBuiltDependencies": [
            "husky",
            "esbuild",
            "sharp"
        ]
    }
}
